    position: absolute; bottom: 6px; left: 6px; font-size: 10px; font-weight: 600;
    padding: 2px 7px; border-radius: 20px; background: #f59e0b; color: #fff; z-index: 2;
  }
  .sob-body { padding: 9px 10px 10px; display: flex; flex-direction: column; gap: 7px; flex: 1; }
  .sob-title {
    font-size: 12.5px; font-weight: 600; color: #1a1a1a; line-height: 1.3;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    min-height: 32px;
  }
  .sob-venues {
    font-size: 10.5px; color: #6b7280; line-height: 1.35; margin-top: -3px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .sob-toggles { display: flex; gap: 6px; flex-wrap: wrap; }
  .sob-toggle {
    font-size: 10.5px; padding: 3px 7px; border-radius: 6px; border: 1px solid #d7dade;
    cursor: pointer; user-select: none; color: #6b7280; background: #f7f8fa;
  }
  .sob-toggle.on { background: #e7f0ff; border-color: #b6d1fb; color: #1a56c4; }
  .sob-toggle:hover { filter: brightness(0.97); }
